{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "peers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "service-id": {
            "type": "string",
            "format": "uri"
          },
          "name": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "links": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "rel": {
                  "type": "string",
                  "enum": [
                    "service"
                  ],
                  "description": "A link relation type that represents the endpoint of the peer service."
                },
                "title": {
                  "type": "string"
                },
                "href": {
                  "type": "string",
                  "format": "uri",
                  "description": "The URL to the endpoint of the peer service."
                }
              },
              "required": [
                "rel",
                "title",
                "href"
              ]
            }
          }
        },
        "required": [
          "service-id",
          "name",
          "version",
          "description",
          "links"
        ]
      }
    }
  },
  "required": [
    "peers"
  ]
}